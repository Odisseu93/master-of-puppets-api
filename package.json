{
  "name": "master-of-puppets-api",
  "version": "1.0.0",
  "description": "Node + VkrunJS + TypeScript API",
  "license": "GPL-3.0-only",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "manage-keys": "ts-node src/scripts/manage-keys.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "vkrun": "^3.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/sqlite3": "^3.1.11",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^17.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.62.1"
  }
}
